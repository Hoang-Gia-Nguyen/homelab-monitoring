# Grafana admin password (change this before production deployment!)
GF_SECURITY_ADMIN_PASSWORD=admin

# Alertmanager SMTP credentials (for email fallback receiver)
# ALERTMANAGER_SMTP_HOST=smtp.gmail.com
# ALERTMANAGER_SMTP_PORT=587
# ALERTMANAGER_SMTP_USER=your-email@gmail.com
# ALERTMANAGER_SMTP_PASS=your-app-password
# ALERTMANAGER_SMTP_FROM=your-email@gmail.com

# GitHub token for CI monitor exporter (repo: read access)
GH_TOKEN=
