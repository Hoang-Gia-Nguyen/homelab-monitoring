{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "datasource", "uid": "grafana" },
        "enable": true,
        "hide": true,
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "panels": [],
      "title": "System Vitality",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${ds_prometheus}" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" }, "unit": "s" } },
      "gridPos": { "h": 3, "w": 6, "x": 0, "y": 1 },
      "id": 10,
      "options": { "justifyMode": "center", "textMode": "value" },
      "title": "Uptime",
      "type": "stat",
      "targets": [{ "expr": "node_time_seconds{instance=\"$node\"} - node_boot_time_seconds{instance=\"$node\"}", "instant": true }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${ds_prometheus}" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "green" } } },
      "gridPos": { "h": 3, "w": 6, "x": 6, "y": 1 },
      "id": 11,
      "options": { "justifyMode": "center", "textMode": "value" },
      "title": "CPU Cores",
      "type": "stat",
      "targets": [{ "expr": "count(count(node_cpu_seconds_total{instance=\"$node\"}) by (cpu))", "instant": true }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${ds_prometheus}" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "purple" }, "unit": "bytes" } },
      "gridPos": { "h": 3, "w": 6, "x": 12, "y": 1 },
      "id": 12,
      "options": { "justifyMode": "center", "textMode": "value" },
      "title": "Total RAM",
      "type": "stat",
      "targets": [{ "expr": "node_memory_MemTotal_bytes{instance=\"$node\"}", "instant": true }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${ds_prometheus}" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "orange" } } },
      "gridPos": { "h": 3, "w": 6, "x": 18, "y": 1 },
      "id": 13,
      "options": { "justifyMode": "center", "textMode": "name" },
      "title": "OS Release",
      "type": "stat",
      "targets": [{ "expr": "node_uname_info{instance=\"$node\"}", "instant": true, "legendFormat": "{{release}}" }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 4 },
      "id": 2,
      "panels": [],
      "title": "Resource Usage (Gauges)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${ds_prometheus}" },
      "fieldConfig": { "defaults": { "max": 100, "min": 0, "unit": "percent", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 80 }, { "color": "red", "value": 90 }] } } },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 5 },
      "id": 20,
      "title": "CPU Usage",
      "type": "gauge",
      "targets": [{ "expr": "100 * (1 - avg(rate(node_cpu_seconds_total{mode=\"idle\",instance=\"$node\"}[$__rate_interval])))" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${ds_prometheus}" },
      "fieldConfig": { "defaults": { "max": 100, "min": 0, "unit": "percent", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 80 }, { "color": "red", "value": 90 }] } } },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 5 },
      "id": 21,
      "title": "RAM Usage",
      "type": "gauge",
      "targets": [{ "expr": "100 * (1 - ((node_memory_MemFree_bytes{instance=\"$node\"} + node_memory_Cached_bytes{instance=\"$node\"} + node_memory_Buffers_bytes{instance=\"$node\"}) / node_memory_MemTotal_bytes{instance=\"$node\"}))" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${ds_prometheus}" },
      "fieldConfig": { "defaults": { "max": 100, "min": 0, "unit": "percent", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 80 }, { "color": "red", "value": 90 }] } } },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 5 },
      "id": 22,
      "title": "Root Filesystem Used",
      "type": "gauge",
      "targets": [{ "expr": "100 * (1 - (node_filesystem_avail_bytes{instance=\"$node\",mountpoint=\"/\"} / node_filesystem_size_bytes{instance=\"$node\",mountpoint=\"/\"}))" }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 3,
      "panels": [],
      "title": "Trends",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${ds_prometheus}" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 10 },
      "id": 30,
      "title": "CPU Usage Trend",
      "type": "timeseries",
      "targets": [
        { "expr": "100 * (1 - avg by(instance) (rate(node_cpu_seconds_total{mode=\"idle\",instance=\"$node\"}[$__rate_interval])))", "legendFormat": "CPU Usage", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${ds_prometheus}" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 10 },
      "id": 33,
      "title": "RAM Usage Trend",
      "type": "timeseries",
      "targets": [
        { "expr": "100 * (1 - ((node_memory_MemFree_bytes{instance=\"$node\"} + node_memory_Cached_bytes{instance=\"$node\"} + node_memory_Buffers_bytes{instance=\"$node\"}) / node_memory_MemTotal_bytes{instance=\"$node\"}))", "legendFormat": "RAM Usage", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${ds_prometheus}" },
      "fieldConfig": { "defaults": { "unit": "binBps" } },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 17 },
      "id": 31,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "title": "Network Traffic (All Interfaces)",
      "type": "timeseries",
      "targets": [
        { "expr": "sum by (device) (rate(node_network_receive_bytes_total{instance=\"$node\", device!~\"lo\"}[$__rate_interval]))", "legendFormat": "Rx: {{device}}", "refId": "A" },
        { "expr": "sum by (device) (rate(node_network_transmit_bytes_total{instance=\"$node\", device!~\"lo\"}[$__rate_interval]))", "legendFormat": "Tx: {{device}}", "refId": "B" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${ds_prometheus}" },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 17 },
      "id": 40,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "title": "Total Egress (Since Boot)",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(node_network_transmit_bytes_total{instance=\"$node\", device!~\"lo\"})", "legendFormat": "Total Egress", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${ds_prometheus}" },
      "fieldConfig": { "defaults": { "unit": "binBps" } },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 17 },
      "id": 32,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "title": "Disk I/O (sda)",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(node_disk_read_bytes_total{instance=\"$node\",device=\"sda\"}[$__rate_interval])", "legendFormat": "Read", "refId": "A" },
        { "expr": "rate(node_disk_written_bytes_total{instance=\"$node\",device=\"sda\"}[$__rate_interval])", "legendFormat": "Write", "refId": "B" }
      ]
    }
  ],
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["gcp", "linux"],
  "templating": {
    "list": [
      {
        "current": { "text": "Prometheus", "value": "Prometheus" },
        "hide": 0,
        "name": "ds_prometheus",
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      },
      {
        "datasource": { "type": "prometheus", "uid": "${ds_prometheus}" },
        "definition": "label_values(node_uname_info{instance=~\"ne-gc-vm.*\"}, instance)",
        "hide": 0,
        "name": "node",
        "query": "label_values(node_uname_info{instance=~\"ne-gc-vm.*\"}, instance)",
        "refresh": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "title": "GCP VM Monitoring",
  "uid": "gcp_vm_monitoring",
  "version": 1
}
